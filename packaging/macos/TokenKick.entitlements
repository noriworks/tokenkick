<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- PyInstaller embeds Python and dynamic libraries inside the app bundle.
       Keep App Sandbox off for v1, but allow the hardened runtime to load
       the bundled libraries explicitly signed by the packaging scripts. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
